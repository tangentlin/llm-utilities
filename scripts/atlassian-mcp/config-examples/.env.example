# Atlassian MCP Configuration
# Copy this file to .env and fill in your values
# Then source it: source .env

# =============================================================================
# JIRA Configuration (Required for JIRA integration)
# =============================================================================

# Your JIRA instance URL
# Cloud: https://your-company.atlassian.net
# Server/DC: https://jira.your-company.com
JIRA_URL="https://your-company.atlassian.net"

# Your Atlassian account email (Cloud) or username (Server/DC)
JIRA_USERNAME="your-email@company.com"

# API Token (Cloud) - Get from: https://id.atlassian.com/manage-profile/security/api-tokens
JIRA_API_TOKEN="your-api-token-here"

# OR Personal Access Token (Server/Data Center only)
# JIRA_PERSONAL_TOKEN="your-pat-here"

# =============================================================================
# Confluence Configuration (Optional - for Confluence integration)
# =============================================================================

# Your Confluence instance URL
# CONFLUENCE_URL="https://your-company.atlassian.net/wiki"

# Same credentials as JIRA (typically)
# CONFLUENCE_USERNAME="your-email@company.com"
# CONFLUENCE_API_TOKEN="your-api-token-here"

# =============================================================================
# Optional Settings
# =============================================================================

# Filter to specific projects (comma-separated)
# JIRA_PROJECTS_FILTER="PROJ,DEV,SUPPORT"

# Read-only mode (set to true to prevent write operations)
# JIRA_READ_ONLY="false"
